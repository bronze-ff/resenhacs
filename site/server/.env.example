# Conexão com o Postgres do Supabase (Settings → Database → Connection string).
# USE O "SESSION POOLER" como padrão: a conexão direta (db.SEU_PROJETO.supabase.co)
# é IPv6-only desde 2024 e falha em redes IPv4 (caso desta máquina) com ENETUNREACH.
# O Session Pooler é IPv4 e funciona com pg.Pool sem mudança de código.
DATABASE_URL=postgresql://postgres.SEU_PROJETO:SENHA@aws-0-us-east-1.pooler.supabase.com:5432/postgres
# (Alternativa, só se sua rede tiver IPv6: postgresql://postgres:SENHA@db.SEU_PROJETO.supabase.co:5432/postgres)
# Chave da Steam Web API: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
# Qualquer string longa e aleatória
JWT_SECRET=
# Origem pública do site (dev: o Vite; prod: o domínio)
APP_URL=http://localhost:5173
PORT=3001

# R2 (Cloudflare) — arquivamento de demos e replays. Sem isso, ingest funciona
# normalmente mas não sobe nada pro R2 (upload_url fica vazio).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=resenha-demos

# OAuth de vínculo FACEIT (Fase A). Sem FACEIT_CLIENT_ID, a rota de vínculo devolve 503.
# FACEIT_CLIENT_SECRET é opcional: só alguns apps FACEIT ("Authorization Code with PKCE")
# exigem Basic Auth no POST do token endpoint mesmo com PKCE; sem ele, a troca de token
# segue só com code_verifier.
FACEIT_CLIENT_ID=
FACEIT_CLIENT_SECRET=

# Allstar (ADR-0004) — clipes de vídeo real gerados sob demanda, restritos a uma allowlist
# de steamId64 (ALLSTAR_STEAM_IDS, separados por vírgula) até o preço por clipe ser
# confirmado com o suporte deles. ALLSTAR_WEBHOOK_AUTH valida o webhook de retorno (mesmo
# valor cadastrado no dashboard deles em "Webhook Auth"); sem ele, /api/allstar/webhook
# rejeita tudo.
ALLSTAR_API_KEY=
ALLSTAR_STEAM_IDS=
ALLSTAR_WEBHOOK_AUTH=
